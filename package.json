{
  "name": "medusa-plugin-better-auth",
  "version": "0.1.0",
  "description": "Better Auth as the authentication engine for Medusa v2 — social OAuth, magic links, passkeys and 2FA for customers and admin users.",
  "license": "MIT",
  "files": [
    ".medusa/server",
    "bin"
  ],
  "bin": {
    "medusa-plugin-better-auth": "./bin/medusa-plugin-better-auth.js"
  },
  "keywords": [
    "medusa",
    "medusa-plugin",
    "medusa-v2",
    "better-auth",
    "authentication",
    "oauth"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./*": "./.medusa/server/src/*.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    }
  },
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "test:unit": "jest",
    "prepublishOnly": "medusa plugin:build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "pg": "^8.13.0"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.15.0",
    "@medusajs/cli": "^2.15.0",
    "@medusajs/framework": "^2.15.0",
    "better-auth": "^1.5.0",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@medusajs/admin-sdk": "2.15.5",
    "@medusajs/admin-shared": "2.15.5",
    "@medusajs/cli": "2.15.5",
    "@medusajs/framework": "2.15.5",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.2",
    "better-auth": "^1.6.23",
    "jest": "^29.7.0",
    "react": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.14"
  },
  "engines": {
    "node": ">=20"
  }
}
